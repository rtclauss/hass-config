        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Battery Sensor"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Z2M Device Availability & Batteries",
  "uid": "z2m-availability-v1",
  "version": 2,
  "weekStart": ""
}
