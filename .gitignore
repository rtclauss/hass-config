########################################
# Ignore everything by default
########################################
*

########################################
# Allow directory traversal
########################################
!*/

########################################
# Allow Home Assistant config files
########################################
!*.yaml
!*.yml
!AGENTS.md
!esphome/tikiroom_effects.h
!.python-version
!README.md
!inventory.md
!specs/
!specs/*.allium
!docs/
!docs/*.md
!.githooks/
!.githooks/**
!scripts/
!scripts/*.py
!scripts/*.sh
!scripts/*.example
!scripts/*.conf.example
!scripts/*.authorized_keys.example
!appdaemon/
!appdaemon/**
!tests/
!tests/*.py
!appdaemon/
appdaemon/*
!appdaemon/apps/
appdaemon/apps/*
!appdaemon/apps/vacuum_stall_monitor.py
!appdaemon/apps/vacuum_stall_monitor.yaml

########################################
# Explicitly ignore sensitive files
########################################
AGENTS.local.md
secrets.yaml
known_devices.yaml
ip_bans.yaml
trusted_networks.yaml
google_calendars.yaml

########################################
# Ignore HA runtime & auth data
########################################
.storage/*
!.storage/lovelace*
!.storage/lovelace_dashboards*
!.storage/lovelace_resources*
!.storage/lovelace.*

########################################
# Ignore backups, logs, databases
########################################
*.log
*.db
*.db-shm
*.db-wal
.backup/
.backups/
cloud/
tts/
deps/
__pycache__/
appdaemon/compiled/
appdaemon/namespaces/
appdaemon/web/
appdaemon/**/__pycache__/
appdaemon/**/*.pyc
appdaemon/drift_model_data.csv

########################################
# Ignore OS / editor junk
########################################
._*
.DS_Store
.vscode/*
!.vscode/settings.json
.vscode/
